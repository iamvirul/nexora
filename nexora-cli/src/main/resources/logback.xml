<configuration>

    <!-- Verbose engine logs go to stderr so they don't pollute piped output -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- User-facing CLI output (INFO from com.nexora.cli) goes to stdout -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.out</target>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Engine internals: warn only, stderr -->
    <logger name="com.nexora.runtime"  level="WARN" additivity="false"><appender-ref ref="STDERR"/></logger>
    <logger name="com.nexora.executor" level="WARN" additivity="false"><appender-ref ref="STDERR"/></logger>
    <logger name="com.nexora.loader"   level="WARN" additivity="false"><appender-ref ref="STDERR"/></logger>
    <logger name="com.nexora.registry" level="WARN" additivity="false"><appender-ref ref="STDERR"/></logger>
    <logger name="nexora.plugin"       level="WARN" additivity="false"><appender-ref ref="STDERR"/></logger>

    <!-- CLI layer: info to stdout, clean format -->
    <logger name="com.nexora.cli" level="INFO" additivity="false"><appender-ref ref="STDOUT"/></logger>

    <root level="WARN"><appender-ref ref="STDERR"/></root>

</configuration>
